# LLM API configuration (supports any LLM API that follows the OpenAI SDK format)
# Recommended: Qwen-plus model on Alibaba Cloud: https://bailian.console.aliyun.com/
# Note: This model has relatively high consumption; you can start with a simulation of fewer than 40 rounds.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep Memory Graph Configuration =====
# The monthly free tier is sufficient for simple use cases: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Optional LLM Boost Configuration =====
# Note: If you do not use the boost configuration, do not include these items in your .env file.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here